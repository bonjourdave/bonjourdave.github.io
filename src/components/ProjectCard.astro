---
import type { GitHubRepo } from '../utils/github.ts';

interface Props {
  repo: GitHubRepo;
}

const { repo } = Astro.props;

const description = repo.description ?? 'No description provided.';
---

<article class="flex flex-col rounded-xl border
                border-zinc-200 dark:border-zinc-700
                bg-white dark:bg-zinc-800
                overflow-hidden
                hover:border-zinc-400 dark:hover:border-zinc-500
                transition-colors">

  <!-- Thumbnail — real image when available, styled placeholder otherwise -->
  {repo.social_preview_image_url ? (
    <img
      src={repo.social_preview_image_url}
      alt={`${repo.name} social preview`}
      width="1280"
      height="640"
      class="w-full aspect-[2/1] object-cover"
    />
  ) : (
    <div class="w-full aspect-[2/1] flex items-center justify-center px-4
                bg-zinc-100 dark:bg-zinc-700">
      <span class="text-sm font-medium text-center truncate
                   text-zinc-400 dark:text-zinc-500">
        {repo.name}
      </span>
    </div>
  )}

  <!-- Card body — the anchor wraps the content for a large touch target -->
  <a
    href={repo.html_url}
    target="_blank"
    rel="noopener noreferrer"
    class="flex flex-col flex-1 gap-2 p-5 min-h-[44px]
           text-inherit no-underline"
  >
    <h2 class="text-base font-semibold
               text-zinc-900 dark:text-zinc-100
               group-hover:text-zinc-600">
      {repo.name}
    </h2>

    <p class="text-sm leading-relaxed line-clamp-3
              text-zinc-500 dark:text-zinc-400">
      {description}
    </p>

    <!-- Language badge — omitted entirely when language is null -->
    {repo.language && (
      <span class="mt-1 self-start text-xs font-medium px-2 py-0.5 rounded-full
                   bg-zinc-100 dark:bg-zinc-700
                   text-zinc-600 dark:text-zinc-300">
        {repo.language}
      </span>
    )}
  </a>

</article>
