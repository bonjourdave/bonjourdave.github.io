---
import type { GitHubRepo } from '../utils/github.ts';

interface Props {
  repos: GitHubRepo[];
}

const { repos } = Astro.props;
---

{repos.length > 0 && (
  <section class="py-10 px-6 bg-white dark:bg-zinc-950">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-xl font-semibold mb-6
                 text-zinc-900 dark:text-zinc-100">
        Collaborations
      </h2>
      <ul class="flex flex-wrap gap-3 list-none p-0" role="list">
        {repos.map((repo) => (
          <li>
            <a
              href={repo.html_url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center min-h-[44px] px-4 py-2.5
                     rounded-lg text-sm font-medium
                     border border-zinc-200 dark:border-zinc-700
                     text-zinc-700 dark:text-zinc-300
                     hover:border-zinc-400 dark:hover:border-zinc-500
                     transition-colors"
            >
              {repo.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}
