# Prevent execution of package lifecycle scripts (preinstall, postinstall, etc.)
# during installs. This is the primary defence against npm supply chain attacks
# that use install hooks as their execution vector (e.g. Shai-Hulud, Sept/Nov 2025).
#
# If a legitimate package genuinely needs an install script, add it explicitly:
#   npm install <package> --ignore-scripts=false
# or run the script manually after verifying it:
#   node node_modules/<package>/install.js
ignore-scripts=true

# Pin exact versions by default (no ^ or ~ ranges) when running npm install.
# Ranges like ^1.2.3 allow automatic minor/patch updates on next install,
# which can silently pull in a compromised version between lockfile updates.
# Exact pinning combined with package-lock.json gives full reproducibility.
save-exact=true
