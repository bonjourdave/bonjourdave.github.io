# .env.example — Copy this to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── GitHub ──────────────────────────────────────────────────────────────────
# Fine-grained Personal Access Token — scoped to this repo only.
# Create one at: https://github.com/settings/tokens?type=beta
#   Resource owner: your GitHub account
#   Repository access: Only select repositories → this repo
#   Permissions:
#     Repository: Contents (read/write), Issues (read/write),
#                 Pull requests (read/write), Workflows (read/write),
#                 Metadata (read, auto-selected)
#
# Used by:
#   • devcontainer → .mcp.json GitHub MCP server (Claude Code tool access)
#   • Astro build-time fetch of your public repos for the gallery
#   • gh CLI inside the container for push/pull/PR operations
#
# Token prefix will be github_pat_  (not ghp_ which is a classic token)
GH_PAT=github_pat_your_token_here

# Your GitHub username — used by Astro to fetch your public repos at build time
PUBLIC_GITHUB_USERNAME=your_github_username
